#chatbot api key and model configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gpt-4o

# MongoDB configuration
# Use localhost when the app runs on the host machine.
# If the app runs inside Docker Compose, use mongodb://mongodb:27017/ instead.
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=porra_db